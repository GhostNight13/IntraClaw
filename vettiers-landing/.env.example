# ─── Analytics ──────────────────────────────────────────────
# Create a free project at https://posthog.com and grab your project API key.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Waitlist form ──────────────────────────────────────────
# Option A (recommended): Tally form — https://tally.so
# Grab the form ID from the share URL: https://tally.so/r/<FORM_ID>
NEXT_PUBLIC_TALLY_FORM_ID=

# Option B: custom API route that posts to a Tally webhook or similar.
# Paste the full webhook URL Tally gives you under "Integrations → Webhook".
TALLY_WEBHOOK_URL=

# ─── Site metadata ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://vettiers.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@vettiers.com
