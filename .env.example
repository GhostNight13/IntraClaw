# ╔══════════════════════════════════════════════════════════════╗
# ║   IntraClaw — environment template                          ║
# ║   Copy to `.env` and fill in only what you need.            ║
# ║   Every block is OPTIONAL — the agent auto-discovers what's ║
# ║   configured and runs with whatever is available.           ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Agent identity ─────────────────────────────────────────────
# Agent name — shown in banners, logs, outgoing signatures.
AGENT_NAME=IntraClaw

# YOU — your name, used by the agent in signatures, emails, reports.
USER_NAME=
# YOUR email — used as sender in cold emails, reports.
USER_EMAIL=
# Optional: one-line bio the agent injects into LLM system prompts.
# Example: "a freelance designer based in Paris" or "a Node.js dev at Acme"
USER_BIO=
# Optional: your business context, added to prompts for content gen.
# Example: "runs a small web agency" or "studies cybersecurity at ETH"
USER_BUSINESS=
# Optional: your personal website / portfolio URL (with or without https://).
USER_WEBSITE=
# Optional: city, country — used in local-time / regional context prompts.
USER_LOCATION=
USER_TIMEZONE=UTC
# Interface language. Currently supported: en, fr.
USER_LANGUAGE=en

# ─── Security (STRONGLY RECOMMENDED) ─────────────────────────────
# Require /yes <code> confirmation before every terminal / file_write step.
# Disable only for non-interactive / CI deployments.
CONFIRMATION_ENABLED=true
# Skip confirmation for specific kinds: terminal, file_write, shell_exec, evolve
# CONFIRMATION_SKIP=
# Extend shell-exec allow-list (comma-separated binaries).
# SHELL_EXEC_ALLOW_EXTRA=terraform,ansible,kubectl
# Extend file-ops protected paths (comma-separated regex).
# FILE_OPS_EXTRA_BLOCKED=my_secret,private_data

# ─── Plugins ─────────────────────────────────────────────────────
# Web agency plugin — enables /prospect /prospects /email + cron jobs for
# prospection + cold-email. Set to true ONLY if you're a freelancer/agency
# using IntraClaw for CRM automation.
ENABLE_AGENCY_AGENTS=false

# ─── LLM providers ──────────────────────────────────────────────
# All optional. IntraClaw auto-discovers available providers in this order:
# 1. Claude CLI (if `claude` binary on PATH)  → zero config, uses your Max sub
# 2. Codex CLI   (if `codex` binary on PATH)
# 3. Gemini CLI  (if `gemini` binary on PATH)
# 4. Ollama      (if OLLAMA_HOST reachable)
# 5. API keys below
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=

# Ollama (local LLM runtime)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Fal.ai / Replicate / ElevenLabs (media generation — optional)
FAL_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Server ─────────────────────────────────────────────────────
PORT=3001
DASHBOARD_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Security ───────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_openssl_rand_base64_32
DB_PASSWORD=change_me
REDIS_PASSWORD=change_me

# ─── Feature flags ──────────────────────────────────────────────
LOOP_ENABLED=false
LOOP_INTERVAL_MS=300000
CONSCIOUSNESS_ENABLED=false
GRAPH_EXECUTOR_ENABLED=false
SELF_IMPROVEMENT_ENABLED=false

# ─── Telegram (optional channel) ────────────────────────────────
# Create a bot via @BotFather, then set your own Telegram user ID
# (find it via @userinfobot). Only this ID can talk to the agent.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_CHAT_ID=

# ─── Discord (REST + Gateway — no library required) ────────────
# Create a bot at https://discord.com/developers/applications
# Ensure the "Message Content Intent" is enabled.
# Leave DISCORD_BOT_TOKEN empty to disable this channel.
DISCORD_BOT_TOKEN=
# Comma-separated Discord user IDs allowed to run slash-style commands:
DISCORD_AUTHORIZED_USERS=
# Default channel ID for broadcast messages (optional):
DISCORD_NOTIFICATION_CHANNEL=

# ─── Slack (Events API — no library required) ──────────────────
# Create a Slack app at https://api.slack.com/apps → enable Events API.
# Configure request URLs:
#   Events:         https://<your-host>/webhooks/slack/events
#   Slash commands: https://<your-host>/webhooks/slack/commands
# Leave SLACK_BOT_TOKEN empty to disable this channel.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Comma-separated Slack user IDs allowed (empty = allow all):
SLACK_AUTHORIZED_USERS=
# Default channel for broadcasts (optional):
SLACK_NOTIFICATION_CHANNEL=

# ─── WhatsApp via Twilio (REST) ────────────────────────────────
# Get credentials at https://console.twilio.com
# Sandbox FROM looks like: whatsapp:+14155238886
# Configure webhook in Twilio console:
#   https://<your-host>/webhooks/whatsapp/incoming
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Comma-separated E.164 numbers (e.g. +14155551212,+32499123456):
WHATSAPP_AUTHORIZED_NUMBERS=

# ─── SMS via Twilio (REST) ─────────────────────────────────────
# Configure webhook in Twilio console:
#   https://<your-host>/webhooks/sms/incoming
TWILIO_SMS_FROM=
# Comma-separated E.164 numbers (empty = deny all):
SMS_AUTHORIZED_NUMBERS=

# ─── Email channel (IMAP poll + SMTP send) ─────────────────────
# Requires `imapflow` and `nodemailer` (npm i imapflow nodemailer).
# Adapter disables itself gracefully if packages are missing.
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
# Comma-separated sender addresses allowed (empty = allow all — NOT recommended):
EMAIL_AUTHORIZED_SENDERS=
# Poll interval in ms (default 60000):
EMAIL_POLL_INTERVAL_MS=60000

# ─── Legacy heavy adapters (library-based) ─────────────────────
# These use the adapter variants in src/channels/adapters/.
# Keep false unless you need the whatsapp-web.js / discord.js / @slack/bolt flow.
ENABLE_WHATSAPP=false
WHATSAPP_OWNER_ID=
ENABLE_DISCORD=false
DISCORD_TOKEN=
ENABLE_SLACK=false
SLACK_APP_TOKEN=

# ─── Matrix (optional) ──────────────────────────────────────────
ENABLE_MATRIX=false
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=
MATRIX_ACCESS_TOKEN=
MATRIX_NOTIFICATION_ROOM=

# ─── Email / Gmail (optional) ───────────────────────────────────
# OAuth flow: see docs/channels.md for step-by-step setup.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_NAME=

# Generic Google OAuth (calendar, drive, contacts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_REFRESH_TOKEN=
ENABLE_GOOGLE_CALENDAR=false

# ─── Notion (optional) ──────────────────────────────────────────
NOTION_TOKEN=
NOTION_API_KEY=
# Optional: pin a specific database for CRM-style workflows
NOTION_PROSPECTS_DB_ID=

# ─── Home Assistant (optional) ──────────────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# ─── Vector DB (optional — ChromaDB) ────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ─── macOS TTS (optional) ───────────────────────────────────────
MACOS_VOICE=
MACOS_VOICE_ID=

# ─── OAuth social login (optional — dashboard) ──────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3001

# ─── SAML SSO (optional — enterprise) ───────────────────────────
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=

# ─── Stripe billing (optional — only if you enable paid tiers) ──
# IntraClaw is open-source and free to self-host. The billing code
# is included for users who want to offer hosted tiers on top.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
