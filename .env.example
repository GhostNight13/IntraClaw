# ╔══════════════════════════════════════╗
# ║   INTRACLAW — Configuration .env    ║
# ╚══════════════════════════════════════╝

# ── AI Models ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ───────────────────────────
DB_PASSWORD=intraclaw_pass_change_me
REDIS_PASSWORD=redis_pass_change_me

# ── Telegram (optionnel) ───────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_ID=

# ── WhatsApp (Phase A) ─────────────────
ENABLE_WHATSAPP=false

# ── Discord (Phase A) ──────────────────
ENABLE_DISCORD=false
DISCORD_TOKEN=

# ── Slack (Phase A) ────────────────────
ENABLE_SLACK=false
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# ── Gmail ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_REFRESH_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Notion ─────────────────────────────
NOTION_TOKEN=
NOTION_API_KEY=

# ── Calendar ───────────────────────────
ENABLE_GOOGLE_CALENDAR=false

# ── Media Generation ───────────────────
FAL_KEY=your_fal_ai_key
REPLICATE_API_TOKEN=your_replicate_token
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=
OPENAI_API_KEY=your_openai_key_for_dalle_fallback

# ── Groq ───────────────────────────────
GROQ_API_KEY=

# ── ChromaDB ───────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ── macOS TTS (local) ──────────────────
MACOS_VOICE=
MACOS_VOICE_ID=

# ── Home Assistant (Phase I) ───────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token

# ── Security ───────────────────────────
JWT_SECRET=change_me_in_production_use_openssl_rand_base64_32

# ── User ───────────────────────────────
USER_NAME=Ayman
USER_EMAIL=
USER_TIMEZONE=Europe/Brussels
USER_LANGUAGE=fr

# ── IntraClaw Settings ─────────────────
LOOP_ENABLED=true
LOOP_INTERVAL_MS=300000
LOG_LEVEL=info

# ── Matrix (Phase A) ───────────────────────────────────
ENABLE_MATRIX=false
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@username:matrix.org
MATRIX_ACCESS_TOKEN=
MATRIX_NOTIFICATION_ROOM=

# ── WhatsApp (Phase A) ─────────────────────────────────
WHATSAPP_OWNER_ID=

# ── Discord (Phase A) ──────────────────────────────────
DISCORD_NOTIFICATION_CHANNEL=

# ── Slack (Phase A) ────────────────────────────────────
SLACK_NOTIFICATION_CHANNEL=
